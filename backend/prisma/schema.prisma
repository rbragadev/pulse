generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum KudosPostStatus {
  ACTIVE
  HIDDEN
  REMOVED
}

enum BadgeRarity {
  COMMON
  UNCOMMON
  RARE
  EPIC
  LEGENDARY
}

enum ReactionType {
  FIRE
  ROCKET
  HEART
  CLAP
  BRAIN
}

enum VoteType {
  TRUSTWORTHY
  COOL
  PROFESSIONAL
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String
  avatar       String?
  googleId     String?  @unique
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  departmentId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department    Department?     @relation(fields: [departmentId], references: [id])
  kudosSent     KudosPost[]     @relation("KudosSent")
  kudosReceived KudosPost[]     @relation("KudosReceived")
  likes         KudosLike[]
  reactions     KudosReaction[]
  comments      KudosComment[]  @relation("CommentAuthor")
  badges        UserBadge[]
  achievements  UserAchievement[]
  seasonRankings SeasonRanking[]
  votesGiven    ProfileVote[]   @relation("VoteGiven")
  votesReceived ProfileVote[]   @relation("VoteReceived")
  visitsMade    ProfileVisit[]  @relation("VisitsMade")
  visitsReceived ProfileVisit[] @relation("VisitsReceived")

  @@map("users")
}

model Department {
  id        String   @id @default(uuid())
  name      String   @unique
  color     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users User[]

  @@map("departments")
}

model KudosCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  icon        String?
  color       String?
  weight      Int      @default(1)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  posts KudosPost[]
  rule  PointRule?

  @@map("kudos_categories")
}

model KudosPost {
  id          String          @id @default(uuid())
  message     String
  authorId    String
  recipientId String
  categoryId  String
  status      KudosPostStatus @default(ACTIVE)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  author    User            @relation("KudosSent", fields: [authorId], references: [id])
  recipient User            @relation("KudosReceived", fields: [recipientId], references: [id])
  category  KudosCategory   @relation(fields: [categoryId], references: [id])
  likes     KudosLike[]
  reactions KudosReaction[]
  comments  KudosComment[]

  @@map("kudos_posts")
}

model KudosLike {
  id        String   @id @default(uuid())
  userId    String
  postId    String
  createdAt DateTime @default(now())

  user User      @relation(fields: [userId], references: [id])
  post KudosPost @relation(fields: [postId], references: [id])

  @@unique([userId, postId])
  @@map("kudos_likes")
}

model PointRule {
  id            String   @id @default(uuid())
  categoryId    String   @unique
  points        Int      @default(1)
  weeklyLimit   Int      @default(10)
  cooldownHours Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  category KudosCategory @relation(fields: [categoryId], references: [id])

  @@map("point_rules")
}

// ─── Gamification ─────────────────────────────────────────────────────────────

model Badge {
  id          String      @id @default(uuid())
  name        String      @unique
  slug        String      @unique
  description String
  icon        String
  color       String
  rarity      BadgeRarity @default(COMMON)
  createdAt   DateTime    @default(now())

  users UserBadge[]

  @@map("badges")
}

model UserBadge {
  id         String   @id @default(uuid())
  userId     String
  badgeId    String
  unlockedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@map("user_badges")
}

model Achievement {
  id             String   @id @default(uuid())
  name           String   @unique
  description    String
  type           String
  conditionValue Int      @default(1)
  icon           String?
  createdAt      DateTime @default(now())

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(uuid())
  userId        String
  achievementId String
  progress      Int       @default(0)
  completed     Boolean   @default(false)
  completedAt   DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}

model Season {
  id        String   @id @default(uuid())
  name      String   @unique
  startDate DateTime
  endDate   DateTime
  active    Boolean  @default(false)
  createdAt DateTime @default(now())

  rankings SeasonRanking[]

  @@map("seasons")
}

model SeasonRanking {
  id       String @id @default(uuid())
  seasonId String
  userId   String
  position Int
  points   Int    @default(0)

  season Season @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([seasonId, userId])
  @@map("season_rankings")
}

model KudosReaction {
  id           String       @id @default(uuid())
  userId       String
  postId       String
  reactionType ReactionType
  createdAt    DateTime     @default(now())

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  post KudosPost @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId, reactionType])
  @@map("kudos_reactions")
}

model KudosComment {
  id        String   @id @default(uuid())
  postId    String
  authorId  String
  message   String
  createdAt DateTime @default(now())

  post   KudosPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  author User      @relation("CommentAuthor", fields: [authorId], references: [id], onDelete: Cascade)

  @@map("kudos_comments")
}

model ProfileVote {
  id        String   @id @default(uuid())
  voterId   String
  targetId  String
  type      VoteType
  createdAt DateTime @default(now())

  voter  User @relation("VoteGiven", fields: [voterId], references: [id], onDelete: Cascade)
  target User @relation("VoteReceived", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([voterId, targetId, type])
  @@map("profile_votes")
}

model ProfileVisit {
  id        String   @id @default(uuid())
  visitorId String
  profileId String
  visitedAt DateTime @default(now())

  visitor User @relation("VisitsMade", fields: [visitorId], references: [id], onDelete: Cascade)
  profile User @relation("VisitsReceived", fields: [profileId], references: [id], onDelete: Cascade)

  @@map("profile_visits")
}
